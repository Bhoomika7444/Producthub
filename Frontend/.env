# Frontend environment variables
# WHY THIS FILE:
#   Vite reads variables that start with VITE_ and makes them available
#   in our React code via import.meta.env.VITE_API_URL
#
# FOR DEVELOPMENT:
#   Leave this as /api — Vite's proxy will forward it to localhost:5000
#
# FOR PRODUCTION (Render, Vercel, etc.):
#   Change this to your live backend URL:
#   VITE_API_URL=https://your-backend.onrender.com/api

VITE_API_URL=https://producthub-backend-ajz8.onrender.com/api
